# MediFlow AI — Environment Variables
# Copy this file to .env and fill in your values before running the application.
# Never commit your .env file to version control.

# =============================================================================
# REQUIRED: Google AI Studio API Key
# =============================================================================
# Used for: All Gemma 4 inference (clinical modules), Gemini 2.5 Flash fallback
# How to get: https://aistudio.google.com/app/apikey (free account, no credit card)
# Model used: gemma-4-31b-it (primary), gemini-2.5-flash (MediScan fallback)
# Note: This key is also used in the browser for the MediScan direct vision call.
#       Scope it to "Generative Language API" read-only if your provider supports it.
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here

# =============================================================================
# REQUIRED: Neon PostgreSQL Database
# =============================================================================
# Used for: Case queue persistence (storing processed cases for the Queue view)
# How to get: https://neon.tech (free tier available, no credit card required)
# Format: postgresql://user:password@host/dbname?sslmode=require
# Note: Neon uses HTTP-based serverless connections that work within Vercel's
#       function timeout constraints. Standard PostgreSQL connection strings
#       with persistent TCP connections will not work on Vercel.
DATABASE_URL=postgresql://user:password@host/mediflow?sslmode=require

# =============================================================================
# OPTIONAL: Local Model Support (Ollama / llama.cpp)
# =============================================================================
# Used for: On-premise inference for healthcare organisations with data-residency
#           requirements (HIPAA, GDPR). When OLLAMA_URL is set, ALL inference
#           is routed to the local endpoint — no data leaves the local network.
# How to set up: https://ollama.ai → install → run: ollama pull gemma3:27b
# Recommended models:
#   gemma3:4b   — 4GB VRAM, development use
#   gemma3:12b  — 8GB VRAM, balanced performance
#   gemma3:27b  — 16GB VRAM, production quality (recommended)
# Leave blank to use Google AI Studio (cloud inference).
OLLAMA_URL=
OLLAMA_MODEL=gemma3:27b

# =============================================================================
# OPTIONAL: Application Configuration
# =============================================================================
# Used for: JWT session signing (if authentication is enabled)
# Generate a secure random value: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Used for: OAuth application ID (if Manus OAuth is enabled)
VITE_APP_ID=your_app_id_here

# =============================================================================
# EXTERNAL APIs (No configuration required — called directly, no keys needed)
# =============================================================================
# The following external APIs are called by MediFlow AI without authentication:
#
# OpenFDA Drug Label API
#   URL: https://api.fda.gov/drug/label.json
#   Used for: Drug-drug interaction checks in MediScan
#   Rate limit: 1000 requests/day without API key; 120,000/day with free API key
#   Docs: https://open.fda.gov/apis/drug/label/
#   No environment variable needed — called directly from api/check-ddi.ts
#
# RxNav / RxNorm Approximate Term API
#   URL: https://rxnav.nlm.nih.gov/REST/approximateTerm.json
#   Used for: Drug name normalisation before OpenFDA queries
#   Rate limit: No published limit; maintained by the US National Library of Medicine
#   Docs: https://lhncbc.nlm.nih.gov/RxNav/APIs/RxNormAPIs.html
#   No environment variable needed — called directly from src/Dashboard.tsx
